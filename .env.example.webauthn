# ═══════════════════════════════════════════════════════════════════════════════
# ALTUVERA BACKEND - ENVIRONMENT CONFIGURATION
# Production-Ready WebAuthn Authentication
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=5000
APP_NAME=Altuvera

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (PostgreSQL/Neon)
# ═══════════════════════════════════════════════════════════════════════════════

# Option 1: Full database URL (for Neon or other cloud databases)
DATABASE_URL=postgresql://user:password@host:5432/altuvera

# Option 2: Individual components (if DATABASE_URL not provided)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=altuvera
DB_USER=postgres
DB_PASSWORD=your_password

# ═══════════════════════════════════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════

# Secret key for signing JWT tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters-recommended

# Expiration time for access tokens
JWT_EXPIRES_IN=7d

# Refresh token secret (optional, can be same as JWT_SECRET)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here

# Refresh token expiration
JWT_REFRESH_EXPIRES_IN=30d

# ═══════════════════════════════════════════════════════════════════════════════
# WEBAUTHN CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Relying Party (RP) Name - displayed to user during authentication
WEBAUTHN_RP_NAME=Altuvera

# Relying Party ID - must match your domain
# For localhost development: localhost
# For production: your-domain.com
WEBAUTHN_RP_ID=altuvera.com

# Origin - protocol + domain (must match WEBAUTHN_RP_ID)
# For localhost development: http://localhost:3000
# For production: https://your-domain.com
WEBAUTHN_ORIGIN=https://altuvera.com

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Frontend URL for email links, redirects, etc.
FRONTEND_URL=https://altuvera.com
FRONTEND_API_URL=https://api.altuvera.com

# ═══════════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Comma-separated list of allowed origins
CORS_ORIGINS=https://altuvera.com,https://www.altuvera.com,http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (for verification emails, notifications, etc.)
# ═══════════════════════════════════════════════════════════════════════════════

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email settings
SUPPORT_EMAIL=support@altuvera.com
FROM_EMAIL=noreply@altuvera.com
FROM_NAME=Altuvera

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication attempt limits
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_ATTEMPTS=5

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

LOG_LEVEL=info
LOG_FILE=logs/app.log

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Cloudinary (for image uploads)
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT/DEBUGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Enable debug mode
DEBUG=false

# HTTPS configuration (for production)
HTTPS_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem
