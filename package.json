{
  "name": "altuvera-backend",
  "version": "1.0.0",
  "description": "Super optimized backend for Altuvera",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "migrate": "node scripts/migrate.js",
    "migrate:down": "node scripts/migrate.js down",
    "seed": "node scripts/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:reset": "npm run migrate:down && npm run migrate && npm run seed"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "nodemailer": "^6.9.7",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "stripe": "^14.7.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.1",
    "slugify": "^1.6.6",
    "date-fns": "^2.30.0",
    "nanoid": "^3.3.7",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "cookie-parser": "^1.4.6",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}