{
  "name": "travel-backend",
  "version": "1.0.0",
  "description": "Altuvera Travel — Enterprise Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "build": "npm run clean && npm run verify:all && npm run check:env && echo Build complete",
    "verify": "node -c server.js && echo server.js OK",
    "verify:all": "node scripts/verify-syntax.js",
    "check:env": "node scripts/check-env.js",
    "clean": "node scripts/clean.js",
    "migrate": "node scripts/migrate.js",
    "rollback": "node scripts/rollback.js",
    "seed": "node scripts/seed.js",
    "db:init": "node -e \"require('./config/db').testConnection().then(() => process.exit(0)).catch(e => { console.error(e.message); process.exit(1); })\"",
    "db:grant": "node scripts/grant-privileges.js",
    "setup-db": "node scripts/setup-database.js",
    "lint": "node scripts/lint-check.js",
    "health": "node scripts/health-check.js",
    "rebuild": "node scripts/rebuild.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes/",
      "controllers/",
      "middleware/",
      "config/",
      "utils/"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "uploads/",
      "*.test.js"
    ],
    "delay": "500",
    "legacyWatch": false
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "resend": "^6.16.0",
    "sequelize": "^6.37.8",
    "sharp": "^0.35.3",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.1",
    "web-push": "^3.6.6",
    "winston": "^3.14.2",
    "yamljs": "^0.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nock": "^13.3.0",
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}



