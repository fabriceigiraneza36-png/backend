# Environment variables for the Altuvera Travel backend
# Copy this to a file named `.env` and fill in the values.

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (PostgreSQL)
# For production (Neon, Render, etc.) - use DATABASE_URL
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgres://neondb_owner:npg_tHirA2BjhbJ3@ep-xxx-pooler.us-east-1.aws.neon.tech/altuvera?sslmode=require&channel_binding=require

# For local development only (when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=altuvera
DB_USER=fabrice
DB_PASSWORD=2004
DB_SSL=false

# JWT
# Must be at least 32 characters
JWT_SECRET=your-very-secure-jwt-secret
JWT_REFRESH_SECRET=your-very-secure-refresh-secret
JWT_EXPIRES_IN=3y
JWT_REFRESH_EXPIRES_IN=3y

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Email (SMTP)
#SMTP_HOST=smtp.mailtrap.io
#SMTP_PORT=587
#SMTP_USER=your-smtp-user
#SMTP_PASS=your-smtp-pass

# Optional: Cloudinary (if you use image uploads)
#CLOUDINARY_CLOUD_NAME=
#CLOUDINARY_API_KEY=
#CLOUDINARY_API_SECRET=
