# Environment variables for the Altuvera Travel backend
# Copy this to a file named `.env` and fill in the values.

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database (PostgreSQL)
# Either provide DATABASE_URL or the individual DB_* values below.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=altuvera
DB_USER=fabrice
DB_PASSWORD=2004

# JWT
# Must be at least 32 characters
JWT_SECRET=your-very-secure-jwt-secret
JWT_REFRESH_SECRET=your-very-secure-refresh-secret

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Email (SMTP)
#SMTP_HOST=smtp.mailtrap.io
#SMTP_PORT=587
#SMTP_USER=your-smtp-user
#SMTP_PASS=your-smtp-pass

# Optional: Cloudinary (if you use image uploads)
#CLOUDINARY_CLOUD_NAME=
#CLOUDINARY_API_KEY=
#CLOUDINARY_API_SECRET=
